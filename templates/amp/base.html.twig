<!DOCTYPE html>
<html amp lang="{{ app.request.locale|default('en') }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width">
        {% set pageTitle %}{% block title %}Welcome!{% endblock %}{% endset %}
        {% set metaDescription %}{% block meta_description %}{% endblock %}{% endset %}
        {% set canonicalUrl %}{% block canonical_url %}{% endblock %}{% endset %}
        {% set robotsContent %}{% block meta_robots %}index,follow{% endblock %}{% endset %}
        {% set ogType %}{% block meta_og_type %}website{% endblock %}{% endset %}
        {# |raw: the captured blocks are already HTML-escaped once; the filters below
           drop Twig's "safe" flag, so without raw the entities would be double-encoded. #}
        <title>{{ pageTitle|trim|raw }}</title>
        {% if metaDescription|trim != '' %}
            <meta name="description" content="{{ metaDescription|striptags|trim|raw }}">
        {% endif %}
        <meta name="robots" content="{{ robotsContent|trim }}">
        {# AMP requires a canonical link pointing at the non-AMP page. #}
        <link rel="canonical" href="{{ canonicalUrl|trim }}">
        <meta property="og:title" content="{{ pageTitle|striptags|trim|raw }}">
        {% if metaDescription|trim != '' %}
            <meta property="og:description" content="{{ metaDescription|striptags|trim|raw }}">
        {% endif %}
        <meta property="og:type" content="{{ ogType|trim }}">
        <meta property="og:site_name" content="{{ 'seo.site_name'|trans }}">
        {% if canonicalUrl|trim != '' %}
            <meta property="og:url" content="{{ canonicalUrl|trim }}">
        {% endif %}
        <link rel="icon" href="/favicon.svg" type="image/svg+xml">
        <link rel="icon" href="/icons/icon-192.png" sizes="192x192" type="image/png">
        <link rel="apple-touch-icon" href="/apple-touch-icon.png">
        <link rel="manifest" href="/manifest.webmanifest">
        <meta name="theme-color" content="#2b6cb0">

        {# Required AMP boilerplate. #}
        <style amp-boilerplate>body{-webkit-animation:-amp-start 8s steps(1,end) 0s 1 normal both;-moz-animation:-amp-start 8s steps(1,end) 0s 1 normal both;-ms-animation:-amp-start 8s steps(1,end) 0s 1 normal both;animation:-amp-start 8s steps(1,end) 0s 1 normal both}@-webkit-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}@-moz-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}@-ms-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}@-o-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}@keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}</style><noscript><style amp-boilerplate>body{-webkit-animation:none;-moz-animation:none;-ms-animation:none;animation:none}</style></noscript>
        <script async src="https://cdn.ampproject.org/v0.js"></script>

        {# Inline the app's compiled CSS — AMP allows exactly one <style amp-custom>. #}
        <style amp-custom>{{ amp_inline_styles() }}</style>

        {% block structured_data %}{% endblock %}
    </head>
    <body>
        {% block body %}{% endblock %}
        <footer class="site-footer">
            <p>
                © {{ 'now'|date('Y') }} {{ 'seo.site_name'|trans }}
                · <a href="{{ path('legal') }}">{{ 'legal.title'|trans }}</a>
                · <a href="{{ path('spot_departments') }}">{{ 'homepage.browse_departments'|trans }}</a>
            </p>
        </footer>
    </body>
</html>
