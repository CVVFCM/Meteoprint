<section class="day" id="forecast-day-{{ day|date('Ymd', 'UTC') }}">
    <h2 class="day__title">
        {{ label|trans({}, 'messages', 'fr') }}
        {# Explicit locale + timezone: this partial is also rendered by the worker (no
           request context). The id above keys the day in UTC (matches the Turbo target);
           the date is shown in Europe/Paris for the reader. #}
        <span class="day__date">{{ day|format_date(pattern: 'EEEE d MMMM', locale: 'fr', timezone: 'Europe/Paris') }}</span>
    </h2>

    {% if forecast is null %}
        <p class="day__loading" aria-live="polite" aria-busy="true">{{ 'forecast.loading'|trans({}, 'messages', 'fr') }}</p>
    {% else %}
        <ul class="slots">
            {% for slot in forecast.slots %}
                {% set weatherLabel = slot.weatherCode|weather_label|trans({}, 'messages', 'fr') %}
                <li class="slot">
                    {% set slotDateTime = (day|date('Y-m-d', 'Europe/Paris') ~ ' ' ~ slot.hour ~ ':00')|date('c', 'Europe/Paris') %}
                    <time class="slot__when" datetime="{{ slotDateTime }}">{{ ('forecast.slot.' ~ slot.hour)|trans({}, 'messages', 'fr') }}</time>
                    <span class="slot__weather">
                        <span class="slot__icon" title="{{ weatherLabel }}">{{ slot.weatherCode|weather_icon(slot.isDay) }}</span>
                        <span class="slot__weather-label">{{ weatherLabel }}</span>
                    </span>
                    <span class="slot__temp">{{ slot.temperature|round }}&nbsp;°C</span>
                    <span class="slot__wind">
                        {# wind_direction_10m is the bearing the wind blows FROM #}
                        <span class="slot__wind-dir">
                            {{ slot.windDirection }}°
                            <span class="slot__arrow" style="transform: rotate({{ slot.windDirection }}deg)" aria-hidden="true">↓</span>
                        </span>
                        <span class="slot__wind-speed">
                            {{ slot.windSpeed|round }}&nbsp;{{ 'forecast.knots'|trans({}, 'messages', 'fr') }}
                            <span class="slot__gust">{{ 'forecast.gusts'|trans({}, 'messages', 'fr') }}&nbsp;{{ slot.windGust|round }}&nbsp;{{ 'forecast.knots'|trans({}, 'messages', 'fr') }}</span>
                        </span>
                    </span>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
</section>
