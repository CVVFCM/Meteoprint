{% extends 'base.html.twig' %}

{% block title %}{{ 'forecast.title'|trans }}{% endblock %}

{% block body %}
    <turbo-mercure-stream-source src="{{ mercure(topic, lastEventId ? { lastEventId: lastEventId } : {}) }}"></turbo-mercure-stream-source>

    <main class="forecast">
        <header class="forecast__head">
            <h1>{{ 'forecast.title'|trans }}</h1>
            {% if spot is not null %}
                <p class="forecast__spot">{{ spot.name }}</p>
            {% endif %}
            <p class="forecast__coords">{{ 'forecast.coordinates'|trans({'%latitude%': position.latitude, '%longitude%': position.longitude}) }}</p>
            <a class="forecast__back" href="{{ path('homepage') }}">{{ 'forecast.back'|trans }}</a>
        </header>

        <div class="forecast__grid">
            {% for entry in days %}
                {{ include('forecast/_day.html.twig', {
                    day: entry.day,
                    forecast: entry.forecast,
                    label: loop.first ? 'forecast.today' : 'forecast.tomorrow',
                }) }}
            {% endfor %}
        </div>
    </main>
{% endblock %}
