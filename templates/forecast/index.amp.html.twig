{% extends 'amp/base.html.twig' %}

{% block title %}{{ block('title', 'forecast/index.html.twig') }}{% endblock %}
{% block meta_description %}{{ block('meta_description', 'forecast/index.html.twig') }}{% endblock %}
{% block canonical_url %}{{ block('canonical_url', 'forecast/index.html.twig') }}{% endblock %}
{% block meta_robots %}{{ block('meta_robots', 'forecast/index.html.twig') }}{% endblock %}

{% block body %}
    {# No <turbo-mercure-stream-source>: AMP forbids custom JS. This template is only
       rendered for fresh forecasts (the renderer 302-redirects to the canonical page
       while a fetch is pending), so no live updates are needed. #}
    <main class="forecast">
        <header class="forecast__head">
            {% if spot is not null %}
                <h1 class="forecast__spot">{{ spot.name }}</h1>
                <p class="forecast__title">{{ 'forecast.title'|trans }}</p>
            {% elseif address %}
                <h1 class="forecast__spot">{{ address }}</h1>
                <p class="forecast__title">{{ 'forecast.title'|trans }}</p>
            {% else %}
                <h1>{{ 'forecast.title'|trans }}</h1>
            {% endif %}
            <p class="forecast__coords">{{ 'forecast.coordinates'|trans({'%latitude%': position.latitude, '%longitude%': position.longitude}) }}</p>
            {% if spot is not null and spot.departmentCode is not null %}
                <a class="forecast__directory" href="{{ path('spot_department', {department: spot.departmentCode}) }}">{{ 'forecast.department_link'|trans({'%department%': spot.departmentCode}) }}</a>
            {% endif %}
            <a class="forecast__back" href="{{ path('homepage') }}">{{ 'forecast.back'|trans }}</a>
        </header>

        <div class="forecast__grid">
            {% for entry in days %}
                {{ include('forecast/_day.html.twig', {
                    day: entry.day,
                    forecast: entry.forecast,
                    label: loop.first ? 'forecast.today' : 'forecast.tomorrow',
                    amp: true,
                }) }}
            {% endfor %}
        </div>

        <p class="forecast__source">{{ 'forecast.source'|trans }}</p>

        <div class="forecast__print-footer">
            <span class="forecast__print-footer-text">{{ 'forecast.footer'|trans }}</span>
            <svg class="forecast__print-footer-logo" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" aria-hidden="true">
                <rect width="512" height="512" rx="104" fill="#2b6cb0"/>
                <circle cx="372" cy="150" r="46" fill="#ffd166"/>
                <path d="M264 92 C300 208 300 312 264 388 L148 388 C188 294 226 194 264 92 Z" fill="#ffffff"/>
                <path d="M116 398 L404 398 C378 448 320 472 260 472 C200 472 152 448 116 398 Z" fill="#e8f1fb"/>
            </svg>
        </div>
    </main>
{% endblock %}
