{% extends 'base.html.twig' %}

{% block title %}{{ 'homepage.meta_title'|trans }}{% endblock %}
{% block meta_description %}{{ 'homepage.meta_description'|trans }}{% endblock %}
{% block canonical_url %}{{ absolute_url(path('homepage')) }}{% endblock %}

{% block body %}
    <main>
        <header>
            <h1>{{ 'homepage.title'|trans }}</h1>
            <p>{{ 'homepage.subtitle'|trans }}</p>
        </header>

        {{ form_start(form) }}
            {{ form_row(form.place) }}
            <button type="submit">{{ 'homepage.submit'|trans }}</button>
        {{ form_end(form) }}
    </main>
{% endblock %}
