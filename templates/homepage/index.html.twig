{% extends 'base.html.twig' %}

{% block title %}{{ 'homepage.meta_title'|trans }}{% endblock %}
{% block meta_description %}{{ 'homepage.meta_description'|trans }}{% endblock %}
{% block canonical_url %}{{ absolute_url(path('homepage')) }}{% endblock %}

{% block body %}
    <main class="home">
        <section class="home__hero">
            <header class="home__intro">
                <h1 class="home__title">{{ 'homepage.title'|trans }}</h1>
                <p class="home__subtitle">{{ 'homepage.subtitle'|trans }}</p>
            </header>

            {{ form_start(form, {attr: {
                class: 'home__form',
                'data-controller': 'auto-submit',
                'data-action': 'change->auto-submit#submit',
            }}) }}
                <div class="home__field">{{ form_row(form.place) }}</div>
                <button type="submit" class="home__submit">{{ 'homepage.submit'|trans }}</button>
            {{ form_end(form) }}
        </section>

        <section class="home__content">
            <p class="home__lead">{{ 'homepage.intro.lead'|trans }}</p>
            <p class="home__browse">
                <a href="{{ path('spot_departments') }}">{{ 'homepage.browse_departments'|trans }}</a>
            </p>

            <article class="home__block">
                <h2>{{ 'homepage.uses.title'|trans }}</h2>
                <p>{{ 'homepage.uses.body'|trans }}</p>
            </article>

            <article class="home__block">
                <h2>{{ 'homepage.how.title'|trans }}</h2>
                <ol class="home__steps">
                    <li>{{ 'homepage.how.step1'|trans }}</li>
                    <li>{{ 'homepage.how.step2'|trans }}</li>
                    <li>{{ 'homepage.how.step3'|trans }}</li>
                </ol>
            </article>

            <article class="home__block home__faq">
                <h2>{{ 'homepage.faq.title'|trans }}</h2>
                <dl>
                    {% for i in 1..3 %}
                        <dt>{{ ('homepage.faq.q' ~ i)|trans }}</dt>
                        <dd>{{ ('homepage.faq.a' ~ i)|trans }}</dd>
                    {% endfor %}
                </dl>
            </article>
        </section>
    </main>
{% endblock %}

{% block structured_data %}
    {% set ld = {
        '@context': 'https://schema.org',
        '@graph': [
            {
                '@type': 'WebApplication',
                name: 'seo.site_name'|trans,
                url: absolute_url(path('homepage')),
                applicationCategory: 'WeatherApplication',
                operatingSystem: 'Web',
                inLanguage: app.request.locale,
                isAccessibleForFree: true,
                description: 'homepage.meta_description'|trans,
            },
            {
                '@type': 'FAQPage',
                mainEntity: [1, 2, 3]|map(i => {
                    '@type': 'Question',
                    name: ('homepage.faq.q' ~ i)|trans,
                    acceptedAnswer: {'@type': 'Answer', text: ('homepage.faq.a' ~ i)|trans},
                }),
            },
        ],
    } %}
    <script type="application/ld+json">{{ ld|json_encode(constant('JSON_UNESCAPED_SLASHES') b-or constant('JSON_UNESCAPED_UNICODE'))|raw }}</script>
{% endblock %}
