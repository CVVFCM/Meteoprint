<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
    <url>
        <loc>{{ homepageUrl }}</loc>
    </url>
    <url>
        <loc>{{ departmentListUrl }}</loc>
    </url>
    <url>
        <loc>{{ legalUrl }}</loc>
    </url>
    {% for spotUrl in spotUrls %}
        <url>
            <loc>{{ spotUrl }}</loc>
        </url>
    {% endfor %}
    {% for departmentUrl in departmentUrls %}
        <url>
            <loc>{{ departmentUrl }}</loc>
        </url>
    {% endfor %}
</urlset>
