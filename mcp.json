{
    "mcpServers": {
        "symfony-ai-mate": {
            "command": "make",
            "args": [
                "mate"
            ]
        },
        "chrome-devtools": {
            "command": "npx",
            "args": [
                "-y",
                "chrome-devtools-mcp@latest",
                "--isolated",
                "--accept-insecure-certs"
            ]
        }
    }
}
