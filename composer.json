{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.5",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6",
        "dunglas/doctrine-json-odm": "^1.5",
        "geocoder-php/nominatim-provider": "^5.8",
        "nyholm/psr7": "^1.8",
        "psr/http-client": "^1.0",
        "symfony/asset-mapper": "8.1.*",
        "symfony/console": "8.1.*",
        "symfony/doctrine-messenger": "8.1.*",
        "symfony/dotenv": "8.1.*",
        "symfony/flex": "^2",
        "symfony/form": "8.1.*",
        "symfony/framework-bundle": "8.1.*",
        "symfony/http-client": "8.1.*",
        "symfony/mercure-bundle": "^0.4.2",
        "symfony/messenger": "8.1.*",
        "symfony/monolog-bundle": "^4.0",
        "symfony/runtime": "8.1.*",
        "symfony/stimulus-bundle": "^3.2",
        "symfony/translation": "8.1.*",
        "symfony/twig-bundle": "8.1.*",
        "symfony/uid": "8.1.*",
        "symfony/ux-autocomplete": "^3.2",
        "symfony/ux-turbo": "^3.2",
        "symfony/validator": "8.1.*",
        "symfony/yaml": "8.1.*",
        "twig/extra-bundle": "^2.12|^3.0",
        "twig/intl-extra": "^3.26",
        "twig/twig": "^2.12|^3.0",
        "willdurand/geocoder-bundle": "*"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "phpstan/extension-installer": true,
            "symfony/ai-mate-composer-plugin": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/",
            "Mate\\": "mate/src/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*",
        "symfony/polyfill-php84": "*",
        "symfony/polyfill-php85": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "reset": [
            "bin/console doctrine:database:create --if-not-exists",
            "bin/console doctrine:schema:drop --force --full-database",
            "bin/console doctrine:migrations:migrate --no-interaction",
            "bin/console doctrine:fixtures:load --no-interaction --append"
        ],
        "reset-test": [
            "bin/console -etest doctrine:database:create --if-not-exists",
            "bin/console -etest doctrine:schema:drop --force --full-database",
            "bin/console -etest doctrine:migrations:migrate --no-interaction",
            "bin/console -etest doctrine:fixtures:load --no-interaction --append"
        ],
        "phpstan": "phpstan analyse",
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.1.*"
        },
        "ai-mate": {
            "extension": false,
            "scan-dirs": [
                "mate/src"
            ],
            "includes": [
                "mate/config.php"
            ]
        }
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^4.3",
        "friendsofphp/php-cs-fixer": "^3.95.11",
        "phpstan/extension-installer": "*",
        "phpstan/phpstan": "*",
        "phpstan/phpstan-doctrine": "*",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "*",
        "phpstan/phpstan-symfony": ">=2.0.20",
        "phpunit/phpunit": "^13.2",
        "symfony/ai-mate": "^0.10.0",
        "symfony/browser-kit": "8.1.*",
        "symfony/css-selector": "8.1.*",
        "symfony/debug-bundle": "8.1.*",
        "symfony/stopwatch": "8.1.*",
        "symfony/web-profiler-bundle": "8.1.*",
        "vincentlanglet/twig-cs-fixer": "^4.0.1"
    }
}
